{
  "name": "@prefer-jsr/source",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for prefer-jsr: ESLint tooling to suggest JSR packages over NPM",
  "license": "MIT",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@nx/eslint": "21.6.4",
    "@nx/eslint-plugin": "21.6.4",
    "@nx/js": "21.6.4",
    "@nx/vite": "21.6.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.21",
    "@swc/helpers": "~0.5.20",
    "@types/node": "20.19.9",
    "@vitest/coverage-v8": "^3.2.4",
    "@vitest/ui": "^3.2.4",
    "eslint": "catalog:eslint",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-dependabot": "^0.6.1",
    "eslint-plugin-package-json": "^0.91.1",
    "eslint-plugin-perfectionist": "catalog:eslint",
    "eslint-yaml": "^0.1.0",
    "jiti": "2.4.2",
    "jsonc-eslint-parser": "^2.4.2",
    "jsr": "^0.14.3",
    "knip": "^5.88.1",
    "nx": "21.6.4",
    "prettier": "^2.8.8",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "verdaccio": "^6.3.2",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=20.9.0"
  },
  "nx": {
    "targets": {
      "lint": {
        "executor": "nx:run-commands",
        "options": {
          "command": "eslint package.json .github/"
        }
      },
      "local-registry": {
        "executor": "@nx/js:verdaccio",
        "options": {
          "port": 4873,
          "config": ".verdaccio/config.yml",
          "storage": "tmp/local-registry/storage"
        }
      }
    }
  }
}
